{
  "name": "vyapai-crm-backend",
  "version": "2.0.0",
  "description": "Vyapai CRM Backend — OpenAI + Supabase + WhatsApp",
  "scripts": {
    "build": "esbuild src/main.jsx --bundle --minify --sourcemap --outfile=public/assets/app.js --jsx=automatic --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:dev": "esbuild src/main.jsx --bundle --sourcemap --outfile=public/assets/app.js --jsx=automatic",
    "dev": "npm run build:dev && wrangler pages dev public",
    "deploy": "npm run build && wrangler pages deploy public"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "hono": "^4.4.6",
    "openai": "^4.28.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "wrangler": "^4.76.0"
  }
}
